{
  "$schema": "https://opencode.ai/config.json",
  "providers": {
    "local": {
      "baseURL": "{{LOCAL_ENDPOINT}}",
      "models": {
        "{{MODEL_ID}}": {
          "tools": true
        }
      }
    }
  },
  "agents": {
    "coder": {
      "model": "local.{{MODEL_ID}}",
      "maxTokens": 8192
    },
    "task": {
      "model": "local.{{MODEL_ID}}",
      "maxTokens": 4096
    },
    "title": {
      "model": "local.{{MODEL_ID}}",
      "maxTokens": 80
    }
  }
}
